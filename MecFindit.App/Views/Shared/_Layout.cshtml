<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>MEC Findit</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<header class="topbar">
    <div class="brand">
        <div class="logo-circle">MEC</div>
        <div>
            <strong>MEC Findit</strong>
            <span>Your Lost & Found Solution</span>
        </div>
    </div>

    <nav>
       @if (Context.Session.GetInt32("UserId") != null)
{
    <a asp-controller="Home" asp-action="Index">Home</a>
    <a asp-controller="Items" asp-action="Search">Search</a>
    <a asp-controller="Items" asp-action="ReportLost">Report Lost</a>
    <a asp-controller="Items" asp-action="ReportFound">Post Found</a>

    @if (Context.Session.GetString("Role") != "Admin")
    {
        <a asp-controller="ClaimRequests" asp-action="MyClaims">My Claims</a>
        <a asp-controller="Notifications" asp-action="Index">Notifications</a>
    }

    @if (Context.Session.GetString("Role") == "Admin")
    {
        <a asp-controller="Admin" asp-action="Dashboard">Admin</a>
        <a asp-controller="Admin" asp-action="ManageUsers">Users</a>
        <a asp-controller="ClaimRequests" asp-action="AdminClaims">Claim Requests</a>
    }

    <span class="welcome-text">
        Welcome, @Context.Session.GetString("FullName")
    </span>

    <a asp-controller="Account" asp-action="Logout">Logout</a>
}
        else
        {
            <a asp-controller="Account" asp-action="Login">Login</a>
            <a asp-controller="Account" asp-action="Register">Register</a>
        }
    </nav>
</header>

<main class="container mt-4 content-area">
    @RenderBody()
</main>

<footer>© @DateTime.Now.Year MEC Findit</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
